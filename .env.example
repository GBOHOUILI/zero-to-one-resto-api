# ─────────────────────────────────────────────────────────────────────────────
# Zero-To-One API — Variables d'environnement
# Copier ce fichier en .env et remplir les valeurs
# cp .env.example .env
# ─────────────────────────────────────────────────────────────────────────────

# ── Application ───────────────────────────────────────────────────────────────
NODE_ENV=development          # development | production | test
PORT=3000
APP_NAME=zero-to-one-api
FRONTEND_URL=http://localhost:3001

# ── Base de données (Supabase / PostgreSQL) ───────────────────────────────────
# Depuis : Supabase > Settings > Database > Connection string (Transaction Pooler)
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres

# ── JWT ───────────────────────────────────────────────────────────────────────
# Générer avec : node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGEME_generate_a_strong_random_secret_64bytes
JWT_REFRESH_SECRET=CHANGEME_generate_a_different_random_secret_64bytes
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── Redis ─────────────────────────────────────────────────────────────────────
# En local : redis://localhost:6379
# En prod (Railway) : redis://default:[PASSWORD]@[HOST]:[PORT]
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=                # Laisser vide en local, requis en prod

# ── Cloudinary (Upload images) ────────────────────────────────────────────────
# Depuis : cloudinary.com > Dashboard
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ── Email (Nodemailer) ────────────────────────────────────────────────────────
# Option A : Gmail avec App Password
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_SECURE=false
MAIL_USER=your_gmail@gmail.com
MAIL_PASS=your_gmail_app_password   # Générer via Google Account > Sécurité > Mots de passe d'application

# Option B : Resend (recommandé en prod)
# MAIL_HOST=smtp.resend.com
# MAIL_PORT=465
# MAIL_SECURE=true
# MAIL_USER=resend
# MAIL_PASS=re_xxxxxxxxxxxx

MAIL_FROM="Zero-To-One <noreply@zero-to-one.bj>"

# ── Multi-tenancy ─────────────────────────────────────────────────────────────
BASE_DOMAIN=zero-to-one.bj         # Domaine de base pour les sous-domaines
TARGET_IP=1.2.3.4                   # IP de votre serveur (pour validation custom domains)

# ── Swagger (Documentation API) ───────────────────────────────────────────────
SWAGGER_USER=admin
SWAGGER_PASS=CHANGEME_swagger_password

# ── Rate Limiting ─────────────────────────────────────────────────────────────
THROTTLE_TTL=60000   # Fenêtre en ms (60 secondes)
THROTTLE_LIMIT=100   # Requêtes max par fenêtre

# ── Sentry (Monitoring erreurs — prod uniquement) ─────────────────────────────
SENTRY_DSN=                    # https://xxx@oxxxxxxx.ingest.sentry.io/xxxxxxx

# ── Logs (Logtail/Datadog — prod uniquement) ──────────────────────────────────
LOGTAIL_SOURCE_TOKEN=          # Token Logtail (Better Stack)
